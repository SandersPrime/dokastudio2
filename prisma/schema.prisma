// schema.prisma - упрощённая версия для SQLite

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// ============================================
// ПОЛЬЗОВАТЕЛИ
// ============================================

model User {
  id                String         @id @default(cuid())
  email             String         @unique
  passwordHash      String         @map("password_hash")
  name              String
  role              String         @default("USER")
  avatarUrl         String?        @map("avatar_url")
  balance           Float          @default(0.0)
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  quizzes           Quiz[]         @relation("Author")
  purchases         Purchase[]
  hostedGames       GameSession[]  @relation("Host")
  hostProfile       HostProfile?
  flashcardSets     FlashcardSet[]
  homeworks         Homework[]
  bookingsAsClient  Booking[]      @relation("Client")
  equipmentOrders   EquipmentOrder[]  // ← вот эта строка
}

model HostProfile {
  id                String         @id @default(cuid())
  userId            String         @unique @map("user_id")
  user              User           @relation(fields: [userId], references: [id])
  bio               String?
  experience        Int            @default(0)
  ratePerHour       Float          @default(1000.0) @map("rate_per_hour")
  rating            Float          @default(5.0)
  isAvailable       Boolean        @default(true) @map("is_available")
  portfolioVideoUrl String?        @map("portfolio_video_url")
  eventsCount       Int            @default(0) @map("events_count")
  
  bookings          Booking[]
}

// ============================================
// КВИЗЫ
// ============================================

model Quiz {
  id                String         @id @default(cuid())
  title             String
  description       String?
  thumbnailUrl      String?        @map("thumbnail_url")
  authorId          String         @map("author_id")
  author            User           @relation("Author", fields: [authorId], references: [id])
  
  isPrivate         Boolean        @default(false) @map("is_private")
  hasTimer          Boolean        @default(true) @map("has_timer")
  timePerQuestion   Int            @default(30)    @map("time_per_question")
  showLeaderboard   Boolean        @default(true) @map("show_leaderboard")
  allowReconnect    Boolean        @default(true) @map("allow_reconnect")
  
  isPublished       Boolean        @default(false) @map("is_published")
  price             Float          @default(0.0)
  discount          Float?         @default(0.0)
  salesCount        Int            @default(0) @map("sales_count")
  
  createdAt         DateTime       @default(now()) @map("created_at")
  updatedAt         DateTime       @updatedAt @map("updated_at")

  rounds            QuizRound[]
  questions         Question[]
  purchases         Purchase[]
  gameSessions      GameSession[]
  homeworks         Homework[]
}

model QuizRound {
  id                String         @id @default(cuid())
  quizId            String         @map("quiz_id")
  quiz              Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  title             String
  order             Int            @map("order_index")
  
  questions         Question[]
}

model Question {
  id                String         @id @default(cuid())
  quizId            String         @map("quiz_id")
  quiz              Quiz           @relation(fields: [quizId], references: [id], onDelete: Cascade)
  roundId           String?        @map("round_id")
  round             QuizRound?     @relation(fields: [roundId], references: [id])
  
  text              String
  imageUrl          String?        @map("image_url")
  audioUrl          String?        @map("audio_url")
  videoUrl          String?        @map("video_url")
  type              String         @default("TEXT")
  points            Int            @default(100)
  order             Int            @map("order_index")
  timeLimit         Int?           @map("time_limit")
  pointsAtStart     Int            @default(100) @map("points_at_start")
  pointsAtEnd       Int            @default(100) @map("points_at_end")
  penaltyPoints     Int            @default(0)   @map("penalty_points")
  penaltyNoAnswer   Int            @default(0)   @map("penalty_no_answer")
  speedBonus1       Int            @default(0)   @map("speed_bonus_1")
  speedBonus2       Int            @default(0)   @map("speed_bonus_2")
  speedBonus3       Int            @default(0)   @map("speed_bonus_3")
  autoJudge         Boolean        @default(true) @map("auto_judge")
  lockoutOnWrong    Boolean        @default(true) @map("lockout_on_wrong")
  showCorrectAnswer Boolean        @default(true) @map("show_correct_answer")
  countdownMode     String         @default("auto") @map("countdown_mode")
  textReveal        String         @default("none") @map("text_reveal")
  jokersEnabled     Boolean        @default(true) @map("jokers_enabled")
  demographicGroup  String?        @map("demographic_group")
  slideRouting      String?        @map("slide_routing")
  notes             String?        @map("notes")

  answers           Answer[]
}

model Answer {
  id                String         @id @default(cuid())
  questionId        String         @map("question_id")
  question          Question       @relation(fields: [questionId], references: [id], onDelete: Cascade)
  text              String
  imageUrl          String?        @map("image_url")
  isCorrect         Boolean        @default(false) @map("is_correct")
  order             Int            @default(0)
}

// ============================================
// МАРКЕТПЛЕЙС
// ============================================

model Purchase {
  id                String         @id @default(cuid())
  userId            String         @map("user_id")
  user              User           @relation(fields: [userId], references: [id])
  quizId            String         @map("quiz_id")
  quiz              Quiz           @relation(fields: [quizId], references: [id])
  
  amount            Float
  platformFee       Float          @map("platform_fee")
  authorEarning     Float          @map("author_earning")
  
  createdAt         DateTime       @default(now()) @map("created_at")
  
  @@unique([userId, quizId])
}

// ============================================
// ОБОРУДОВАНИЕ
// ============================================

model Equipment {
  id                String         @id @default(cuid())
  name              String
  description       String?
  category          String
  priceBuy          Float?         @map("price_buy")
  priceRentDay      Float?         @map("price_rent_day")
  stockCount        Int            @default(0) @map("stock_count")
  availableForRent  Boolean        @default(true) @map("available_for_rent")
  imageUrl          String?        @map("image_url")  // Одна картинка вместо массива
  
  orders            EquipmentOrder[]
}

model EquipmentOrder {
  id                String         @id @default(cuid())
  userId            String         @map("user_id")
  user              User           @relation(fields: [userId], references: [id])
  equipmentId       String         @map("equipment_id")
  equipment         Equipment      @relation(fields: [equipmentId], references: [id])
  
  type              String         // "BUY" или "RENT"
  quantity          Int
  totalPrice        Float          @map("total_price")
  rentStart         DateTime?      @map("rent_start")
  rentEnd           DateTime?      @map("rent_end")
  status            String         @default("PENDING") // PENDING, CONFIRMED, SHIPPED, DELIVERED, RETURNED, CANCELLED
  deliveryAddress   String?        @map("delivery_address")
  
  createdAt         DateTime       @default(now()) @map("created_at")
}

// ============================================
// БИРЖА ВЕДУЩИХ
// ============================================

model Booking {
  id                String         @id @default(cuid())
  hostId            String         @map("host_id")
  host              HostProfile    @relation(fields: [hostId], references: [id])
  clientId          String         @map("client_id")
  client            User           @relation("Client", fields: [clientId], references: [id])
  
  eventDate         DateTime       @map("event_date")
  durationHours     Int            @map("duration_hours")
  totalPrice        Float          @map("total_price")
  status            String         @default("SEARCH") // SEARCH, OFFERED, CONFIRMED, PAID, COMPLETED, CANCELLED
  comment           String?
  
  createdAt         DateTime       @default(now()) @map("created_at")
}

// ============================================
// ИГРОВЫЕ СЕССИИ
// ============================================

model GameSession {
  id                String         @id @default(cuid())
  quizId            String         @map("quiz_id")
  quiz              Quiz           @relation(fields: [quizId], references: [id])
  hostId            String         @map("host_id")
  host              User           @relation("Host", fields: [hostId], references: [id])
  
  pinCode           String         @unique @map("pin_code")
  status            String         @default("LOBBY") // LOBBY, COUNTDOWN, QUESTION, SHOW_ANSWER, LEADERBOARD, FINISHED
  currentQuestionIndex Int         @default(0) @map("current_question_index")
  currentRoundId    String?        @map("current_round_id")
  
  startedAt         DateTime?      @map("started_at")
  finishedAt        DateTime?      @map("finished_at")
  createdAt         DateTime       @default(now()) @map("created_at")
  
  players           GamePlayer[]
  teams             Team[]
}

model GamePlayer {
  id                String         @id @default(cuid())
  sessionId         String         @map("session_id")
  session           GameSession    @relation(fields: [sessionId], references: [id])
  
  userId            String?        @map("user_id")
  nickname          String
  score             Int            @default(0)
  correctAnswers    Int            @default(0) @map("correct_answers")
  
  connected         Boolean        @default(true)
  socketId          String?        @map("socket_id")
  teamId            String?        @map("team_id")
  team              Team?          @relation(fields: [teamId], references: [id])
  
  answers           PlayerAnswer[]
  
  createdAt         DateTime       @default(now()) @map("created_at")
}

model PlayerAnswer {
  id                String         @id @default(cuid())
  playerId          String         @map("player_id")
  player            GamePlayer     @relation(fields: [playerId], references: [id])
  questionId        String         @map("question_id")
  
  answerId          String?        @map("answer_id")
  answerText        String?        @map("answer_text")
  isCorrect         Boolean        @default(false) @map("is_correct")
  pointsAwarded     Int            @default(0) @map("points_awarded")
  responseTimeMs    Int            @map("response_time_ms")
  
  createdAt         DateTime       @default(now()) @map("created_at")
}

model Team {
  id                String         @id @default(cuid())
  sessionId         String         @map("session_id")
  session           GameSession    @relation(fields: [sessionId], references: [id])
  name              String
  captainId         String?        @map("captain_id")
  score             Int            @default(0)
  
  players           GamePlayer[]
  
  createdAt         DateTime       @default(now()) @map("created_at")
}

// ============================================
// FLASHCARDS
// ============================================

model FlashcardSet {
  id          String   @id @default(cuid())
  title       String
  description String?
  authorId    String   @map("author_id")
  author      User     @relation(fields: [authorId], references: [id])
  
  isPublished Boolean  @default(false) @map("is_published")
  price       Float    @default(0.0)
  
  cards       Flashcard[]
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")
}

model Flashcard {
  id          String   @id @default(cuid())
  setId       String   @map("set_id")
  set         FlashcardSet @relation(fields: [setId], references: [id], onDelete: Cascade)
  
  term        String
  definition  String
  imageUrl    String?   @map("image_url")
  audioUrl    String?   @map("audio_url")
  
  order       Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at")
}

// ============================================
// HOMEWORK
// ============================================

model Homework {
  id              String        @id @default(cuid())
  name            String
  description     String?
  quizId          String        @map("quiz_id")
  quiz            Quiz          @relation(fields: [quizId], references: [id])
  authorId        String        @map("author_id")
  author          User          @relation(fields: [authorId], references: [id])
  pinCode         String        @unique @map("pin_code")
  deadline        DateTime
  timeLimit       Int           @default(0)  @map("time_limit")
  maxAttempts     Int           @default(1)  @map("max_attempts")
  shuffleQuestions Boolean      @default(false) @map("shuffle_questions")
  showAnswersAfter Boolean      @default(true) @map("show_answers_after")
  createdAt       DateTime      @default(now()) @map("created_at")
  
  submissions     HomeworkSubmission[]
}

model HomeworkSubmission {
  id          String   @id @default(cuid())
  homeworkId  String   @map("homework_id")
  homework    Homework @relation(fields: [homeworkId], references: [id], onDelete: Cascade)
  studentName String   @map("student_name")
  studentId   String?  @map("student_id")
  startedAt   DateTime @default(now()) @map("started_at")
  completedAt DateTime? @map("completed_at")
  score       Int      @default(0)
  timeSpent   Int      @default(0)  @map("time_spent")
  answers     String   @default("[]") // JSON храним как строку
  attempt     Int      @default(1)
  
  @@unique([homeworkId, studentName, attempt])
}